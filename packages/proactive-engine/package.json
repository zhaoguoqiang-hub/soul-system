{
  "name": "@soul-system/proactive-engine",
  "version": "0.1.0",
  "description": "主动引擎插件：为OpenClaw提供内生目标系统、后台反思线程与主动触发能力",
  "type": "module",
  "main": "index.js",
  "openclaw": {
    "extensions": ["./index.js"]
  },
  "exports": {
    ".": {
      "import": "./index.js",
      "types": "./index.d.ts"
    }
  },
  "peerDependencies": {
    "openclaw": ">=2026.1.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  },
  "keywords": ["openclaw", "plugin", "soul", "proactive", "goal-manager", "reflection"]
}
