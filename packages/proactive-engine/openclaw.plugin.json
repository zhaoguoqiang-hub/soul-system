{
  "id": "proactive-engine",
  "name": "Proactive Engine",
  "description": "周期性地检查上下文，主动写入记忆，是soul-system的心跳",
  "version": "1.1.0",
  "main": "index.ts",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "checkIntervalMs": {
        "type": "number",
        "description": "主动检查间隔（毫秒），默认2小时",
        "default": 7200000
      }
    }
  }
}
