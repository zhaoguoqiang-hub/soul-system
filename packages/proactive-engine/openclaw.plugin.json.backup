{
  "id": "proactive-engine",
  "name": "Soul Proactive Engine",
  "description": "主动引擎：内生目标系统 + 后台反思线程 + 主动触发。让AI助理从被动响应转向积极主动。",
  "version": "0.1.0",
  "author": "soul-system",
  "license": "MIT",
  "skills": [],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "reflectionIntervalMs": {
        "type": "number",
        "description": "反思线程运行间隔（毫秒）",
        "default": 3600000
      },
      "idleThresholdMs": {
        "type": "number",
        "description": "用户无交互后进入深度反思的阈值（毫秒）",
        "default": 300000
      },
      "maxActiveGoals": {
        "type": "number",
        "description": "最大活跃目标数",
        "default": 10
      },
      "enableProactiveTrigger": {
        "type": "boolean",
        "description": "是否启用主动触发",
        "default": true
      }
    }
  },
  "uiHints": {}
}
