{
  "name": "user-context-scanner",
  "version": "0.5.0",
  "description": "用户画像扫描器：构建和维护动态用户画像，支持独立CLI和proactive-engine协作。",
  "main": "scripts/scanner.js",
  "bin": {
    "soul_scanner": "./bin/soul_scanner.js"
  },
  "scripts": {
    "start": "node scripts/scanner.js",
    "test": "node scripts/test-basic.js",
    "cli": "node bin/soul_scanner.js",
    "scan-example": "node bin/soul_scanner.js scan",
    "profile-example": "node bin/soul_scanner.js profile",
    "signal-test": "node bin/soul_scanner.js --process-signal user_preference_mentioned"
  },
  "dependencies": {
    "date-fns": "^3.6.0",
    "natural": "^6.11.2",
    "commander": "^11.0.0",
    "chalk": "^5.3.0"
  },
  "keywords": [
    "soul-system",
    "user-context",
    "profile-scanner",
    "behavior-analysis",
    "cli-tool",
    "proactive-engine"
  ],
  "author": "soul-system",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zhaoguoqiang-hub/soul-system"
  },
  "homepage": "https://github.com/zhaoguoqiang-hub/soul-system/tree/main/packages/user-context-scanner",
  "bugs": {
    "url": "https://github.com/zhaoguoqiang-hub/soul-system/issues"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}