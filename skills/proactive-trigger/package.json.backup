{
  "name": "proactive-trigger",
  "version": "0.6.0",
  "description": "主动触发引擎：基于话题热度衰减模型和沉默等待指数，智能判断触发时机，支持独立CLI和proactive-engine协作。",
  "main": "scripts/trigger.js",
  "bin": {
    "soul_trigger": "./bin/soul_trigger.js"
  },
  "scripts": {
    "start": "node scripts/trigger.js",
    "test": "node scripts/test-basic.js",
    "cli": "node bin/soul_trigger.js",
    "check-example": "node bin/soul_trigger.js check --mode deep",
    "suggest-example": "node bin/soul_trigger.js suggest --context learning",
    "execute-example": "node bin/soul_trigger.js execute --type schedule_reminder",
    "signal-test": "node bin/soul_trigger.js --process-signal user_silent"
  },
  "dependencies": {
    "date-fns": "^3.6.0",
    "commander": "^11.0.0",
    "chalk": "^5.3.0"
  },
  "keywords": [
    "soul-system",
    "proactive-trigger",
    "active-engagement",
    "timing-engine",
    "cli-tool",
    "proactive-engine"
  ],
  "author": "soul-system",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zhaoguoqiang-hub/soul-system"
  },
  "homepage": "https://github.com/zhaoguoqiang-hub/soul-system/tree/main/packages/proactive-trigger",
  "bugs": {
    "url": "https://github.com/zhaoguoqiang-hub/soul-system/issues"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}