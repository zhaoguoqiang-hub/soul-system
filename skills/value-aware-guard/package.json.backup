{
  "name": "value-aware-guard",
  "version": "0.5.0",
  "description": "价值守护系统：监控价值漂移，检查边界违规，执行渐进式干预，支持独立CLI和proactive-engine协作。",
  "main": "scripts/guard.js",
  "bin": {
    "soul_guard": "./bin/soul_guard.js"
  },
  "scripts": {
    "start": "node scripts/guard.js",
    "test": "node scripts/test-basic.js",
    "cli": "node bin/soul_guard.js",
    "monitor-example": "node bin/soul_guard.js monitor",
    "check-example": "node bin/soul_guard.js check --boundary time",
    "report-example": "node bin/soul_guard.js report",
    "signal-test": "node bin/soul_guard.js --process-signal value_drift_detected"
  },
  "dependencies": {
    "date-fns": "^3.6.0",
    "commander": "^11.0.0",
    "chalk": "^5.3.0"
  },
  "keywords": [
    "soul-system",
    "value-guard",
    "boundary-protection",
    "intervention-system",
    "cli-tool",
    "proactive-engine"
  ],
  "author": "soul-system",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zhaoguoqiang-hub/soul-system"
  },
  "homepage": "https://github.com/zhaoguoqiang-hub/soul-system/tree/main/packages/value-aware-guard",
  "bugs": {
    "url": "https://github.com/zhaoguoqiang-hub/soul-system/issues"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}